# =============================================================================
# Sofa Plus+ BOM — Environment Variables Template
# =============================================================================
# Copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# cp .env.example .env

# -----------------------------------------------------------------------------
# Database — Supabase PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_POOL_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret-key-before-deploy
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# -----------------------------------------------------------------------------
# Frontend (React + Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]
